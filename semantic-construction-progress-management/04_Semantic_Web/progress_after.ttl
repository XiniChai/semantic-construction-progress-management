@prefix : <http://www.semanticweb.org/cmpb/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/cmpb/> .

<http://www.semanticweb.org/cmpb> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/bot#containsZone
<https://w3id.org/bot#containsZone> rdf:type owl:ObjectProperty ;
                                    rdfs:domain <https://w3id.org/bot#Zone> ;
                                    rdfs:range <https://w3id.org/bot#Zone> .


###  https://w3id.org/bot#hasBuilding
<https://w3id.org/bot#hasBuilding> rdf:type owl:ObjectProperty ;
                                   rdfs:subPropertyOf <https://w3id.org/bot#containsZone> ;
                                   rdfs:domain <https://w3id.org/bot#Zone> ;
                                   rdfs:range <https://w3id.org/bot#Building> .


###  https://w3id.org/bot#hasElement
<https://w3id.org/bot#hasElement> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf owl:topObjectProperty ;
                                  rdfs:domain <https://w3id.org/bot#Zone> ;
                                  rdfs:range <https://w3id.org/bot#Element> .


###  https://w3id.org/bot#hasSpace
<https://w3id.org/bot#hasSpace> rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf <https://w3id.org/bot#containsZone> ;
                                rdfs:domain <https://w3id.org/bot#Zone> ;
                                rdfs:range <https://w3id.org/bot#Space> .


###  https://w3id.org/bot#hasStorey
<https://w3id.org/bot#hasStorey> rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf <https://w3id.org/bot#containsZone> ;
                                 rdfs:domain <https://w3id.org/bot#Zone> ;
                                 rdfs:range <https://w3id.org/bot#Storey> .


###  https://w3id.org/digitalconstruction/0.5/Processes#hasObject
<https://w3id.org/digitalconstruction/0.5/Processes#hasObject> rdf:type owl:ObjectProperty ;
                                                               rdfs:subPropertyOf owl:topObjectProperty ;
                                                               rdfs:domain <https://w3id.org/digitalconstruction/0.5/Processes#ObjectActivity> .


###  https://w3id.org/digitalconstruction/0.5/Processes#isObservedBy
<https://w3id.org/digitalconstruction/0.5/Processes#isObservedBy> rdf:type owl:ObjectProperty ;
                                                                  rdfs:subPropertyOf owl:topObjectProperty .


###  https://w3id.org/digitalconstruction/Entities#hasActivity
<https://w3id.org/digitalconstruction/Entities#hasActivity> rdf:type owl:ObjectProperty ;
                                                            owl:inverseOf <https://w3id.org/digitalconstruction/Entities#hasState> ;
                                                            rdfs:range <https://w3id.org/digitalconstruction/0.5/Processes#Activity> .


###  https://w3id.org/digitalconstruction/Entities#hasEquipment
<https://w3id.org/digitalconstruction/Entities#hasEquipment> rdf:type owl:ObjectProperty ;
                                                             rdfs:subPropertyOf owl:topObjectProperty ;
                                                             rdfs:domain <https://w3id.org/digitalconstruction/0.5/Processes#Activity> ;
                                                             rdfs:range <https://w3id.org/digitalconstruction/Entities#Equipment> .


###  https://w3id.org/digitalconstruction/Entities#hasGroupActivity
<https://w3id.org/digitalconstruction/Entities#hasGroupActivity> rdf:type owl:ObjectProperty ;
                                                                 rdfs:subPropertyOf owl:topObjectProperty ;
                                                                 rdfs:domain <https://w3id.org/digitalconstruction/0.5/Processes#Activity> ;
                                                                 rdfs:range <https://w3id.org/digitalconstruction/0.5/Processes#Activity> .


###  https://w3id.org/digitalconstruction/Entities#hasParticipant
<https://w3id.org/digitalconstruction/Entities#hasParticipant> rdf:type owl:ObjectProperty ;
                                                               rdfs:subPropertyOf owl:topObjectProperty ;
                                                               rdfs:domain <https://w3id.org/digitalconstruction/0.5/Processes#ObjectActivity> .


###  https://w3id.org/digitalconstruction/Entities#hasState
<https://w3id.org/digitalconstruction/Entities#hasState> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <https://w3id.org/digitalconstruction/0.5/Processes#Activity> ;
                                                         rdfs:range <https://w3id.org/digitalconstruction/Entities#ActivityContext> .


###  https://w3id.org/digitalconstruction/Entities#isLocationOf
<https://w3id.org/digitalconstruction/Entities#isLocationOf> rdf:type owl:ObjectProperty ;
                                                             rdfs:subPropertyOf owl:topObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://www.owl-ontologies.com/cSite#hasActualDuration
<http://www.owl-ontologies.com/cSite#hasActualDuration> rdf:type owl:DatatypeProperty ;
                                                        rdfs:subPropertyOf owl:topDataProperty .


###  http://www.owl-ontologies.com/cSite#hasActualFinish
<http://www.owl-ontologies.com/cSite#hasActualFinish> rdf:type owl:DatatypeProperty ;
                                                      rdfs:subPropertyOf owl:topDataProperty ;
                                                      rdfs:domain <https://w3id.org/digitalconstruction/0.5/Processes#Activity> .


###  http://www.owl-ontologies.com/cSite#hasActualStart
<http://www.owl-ontologies.com/cSite#hasActualStart> rdf:type owl:DatatypeProperty ;
                                                     rdfs:domain <https://w3id.org/digitalconstruction/0.5/Processes#Activity> .


###  http://www.semanticweb.org/cmpb/hasElevation
:hasElevation rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty .


###  http://www.semanticweb.org/cmpb/hasGrid
:hasGrid rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty .


###  http://www.semanticweb.org/cmpb/hasHeight
:hasHeight rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :hasSize .


###  http://www.semanticweb.org/cmpb/hasID
:hasID rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty .


###  http://www.semanticweb.org/cmpb/hasLength
:hasLength rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :hasSize .


###  http://www.semanticweb.org/cmpb/hasQuantity
:hasQuantity rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty .


###  http://www.semanticweb.org/cmpb/hasSize
:hasSize rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/cmpb/hasVolume
:hasVolume rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty .


###  http://www.semanticweb.org/cmpb/hasWeight
:hasWeight rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain <https://w3id.org/digitalconstruction/Entities#ActivityContext> .


###  http://www.semanticweb.org/cmpb/hasWidth
:hasWidth rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :hasSize .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/cmpb/EnvelopeComponents
:EnvelopeComponents rdf:type owl:Class ;
                    rdfs:subClassOf <https://w3id.org/bot#Element> .


###  http://www.semanticweb.org/cmpb/StructuralComponents
:StructuralComponents rdf:type owl:Class ;
                      rdfs:subClassOf <https://w3id.org/bot#Element> .


###  https://brickschema.org/schema/Brick#Camera
<https://brickschema.org/schema/Brick#Camera> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://brickschema.org/schema/Brick#Sensor> .


###  https://brickschema.org/schema/Brick#Sensor
<https://brickschema.org/schema/Brick#Sensor> rdf:type owl:Class .


###  https://w3id.org/bot#Building
<https://w3id.org/bot#Building> rdf:type owl:Class ;
                                rdfs:subClassOf <https://w3id.org/bot#Zone> .


###  https://w3id.org/bot#Element
<https://w3id.org/bot#Element> rdf:type owl:Class ;
                               rdfs:subClassOf <https://w3id.org/digitalconstruction/Entities#BuildingObject> .


###  https://w3id.org/bot#Site
<https://w3id.org/bot#Site> rdf:type owl:Class ;
                            rdfs:subClassOf <https://w3id.org/bot#Zone> .


###  https://w3id.org/bot#Space
<https://w3id.org/bot#Space> rdf:type owl:Class ;
                             rdfs:subClassOf <https://w3id.org/bot#Zone> .


###  https://w3id.org/bot#Storey
<https://w3id.org/bot#Storey> rdf:type owl:Class ;
                              rdfs:subClassOf <https://w3id.org/bot#Zone> .


###  https://w3id.org/bot#Zone
<https://w3id.org/bot#Zone> rdf:type owl:Class .


###  https://w3id.org/digitalconstruction/0.5/Agents#Person
<https://w3id.org/digitalconstruction/0.5/Agents#Person> rdf:type owl:Class ;
                                                         rdfs:subClassOf <https://w3id.org/digitalconstruction/0.5/Processes#Resource> .


###  https://w3id.org/digitalconstruction/0.5/Processes#Activity
<https://w3id.org/digitalconstruction/0.5/Processes#Activity> rdf:type owl:Class .


###  https://w3id.org/digitalconstruction/0.5/Processes#ActivityGroup
<https://w3id.org/digitalconstruction/0.5/Processes#ActivityGroup> rdf:type owl:Class ;
                                                                   rdfs:subClassOf <https://w3id.org/digitalconstruction/0.5/Processes#Activity> ;
                                                                   owl:disjointWith <https://w3id.org/digitalconstruction/0.5/Processes#ObjectActivity> .


###  https://w3id.org/digitalconstruction/0.5/Processes#ObjectActivity
<https://w3id.org/digitalconstruction/0.5/Processes#ObjectActivity> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <https://w3id.org/digitalconstruction/0.5/Processes#Activity> .


###  https://w3id.org/digitalconstruction/0.5/Processes#Resource
<https://w3id.org/digitalconstruction/0.5/Processes#Resource> rdf:type owl:Class .


###  https://w3id.org/digitalconstruction/Entities#ActivityContext
<https://w3id.org/digitalconstruction/Entities#ActivityContext> rdf:type owl:Class ;
                                                                rdfs:subClassOf <https://w3id.org/digitalconstruction/0.5/Processes#Activity> .


###  https://w3id.org/digitalconstruction/Entities#BuildingObject
<https://w3id.org/digitalconstruction/Entities#BuildingObject> rdf:type owl:Class .


###  https://w3id.org/digitalconstruction/Entities#Equipment
<https://w3id.org/digitalconstruction/Entities#Equipment> rdf:type owl:Class ;
                                                          rdfs:subClassOf <https://w3id.org/digitalconstruction/0.5/Processes#Resource> .


