cSite:hasActualDuration a owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty .

cSite:hasActualFinish a owl:DatatypeProperty ;
    rdfs:domain dicp:Activity ;
    rdfs:subPropertyOf owl:topDataProperty .

cSite:hasActualStart a owl:DatatypeProperty ;
    rdfs:domain dicp:Activity .

<http://www.semanticweb.org/cmpb> a owl:Ontology .

cpmb:EnvelopeComponents a owl:Class ;
    rdfs:subClassOf bot:Element .

cpmb:InTrainsit a owl:NamedIndividual,
        dice:ActivityContext ;
    owl:sameAs cpmb:Installed,
        cpmb:Storage .

cpmb:P2 a owl:NamedIndividual,
        dicp:ActivityGroup .

cpmb:P3 a owl:NamedIndividual,
        dicp:ActivityGroup .

cpmb:P4 a owl:NamedIndividual,
        dicp:ActivityGroup .

cpmb:hasElevation a owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty .

cpmb:hasGrid a owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty .

cpmb:hasHeight a owl:DatatypeProperty ;
    rdfs:subPropertyOf cpmb:hasSize .

cpmb:hasID a owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty .

cpmb:hasLength a owl:DatatypeProperty ;
    rdfs:subPropertyOf cpmb:hasSize .

cpmb:hasQuantity a owl:DatatypeProperty ;
