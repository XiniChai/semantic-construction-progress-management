    rdfs:subPropertyOf owl:topDataProperty .

cpmb:hasWidth a owl:DatatypeProperty ;
    rdfs:subPropertyOf cpmb:hasSize .

bot:Site a owl:Class ;
    rdfs:subClassOf bot:Zone .

bot:hasBuilding a owl:ObjectProperty ;
    rdfs:domain bot:Zone ;
    rdfs:range bot:Building ;
    rdfs:subPropertyOf bot:containsZone .

bot:hasElement a owl:ObjectProperty ;
    rdfs:domain bot:Zone ;
    rdfs:range bot:Element ;
    rdfs:subPropertyOf owl:topObjectProperty .

bot:hasSpace a owl:ObjectProperty ;
    rdfs:domain bot:Zone ;
    rdfs:range bot:Space ;
    rdfs:subPropertyOf bot:containsZone .

bot:hasStorey a owl:ObjectProperty ;
    rdfs:domain bot:Zone ;
    rdfs:range bot:Storey ;
    rdfs:subPropertyOf bot:containsZone .

dicp:hasObject a owl:ObjectProperty ;
    rdfs:domain dicp:ObjectActivity ;
    rdfs:subPropertyOf owl:topObjectProperty .

dicp:isObservedBy a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

dice:hasActivity a owl:ObjectProperty ;
    rdfs:range dicp:Activity ;
    owl:inverseOf dice:hasState .

dice:hasEquipment a owl:ObjectProperty ;
    rdfs:domain dicp:Activity ;
    rdfs:range dice:Equipment ;
    rdfs:subPropertyOf owl:topObjectProperty .

dice:hasGroupActivity a owl:ObjectProperty ;
    rdfs:domain dicp:Activity ;
    rdfs:range dicp:Activity ;
    rdfs:subPropertyOf owl:topObjectProperty .

dice:hasParticipant a owl:ObjectProperty ;
    rdfs:domain dicp:ObjectActivity ;
    rdfs:subPropertyOf owl:topObjectProperty .

dice:isLocationOf a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

